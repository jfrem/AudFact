APP_ENV=development
WRAP_API_BASE=http://nginx
WEBHOOK_URL=http://localhost:8080/app/wrap/webhook.php
CAPABILITIES_URL=http://localhost:8080/app/wrap/capabilities.php

DB_TYPE=sqlsrv
DB_HOST=localhost
DB_PORT=1433
DB_NAME=mi_base
DB_USER=sa
DB_PASS=
DB_POOLING=1

GOOGLE_DRIVE_CLIENT_EMAIL=
