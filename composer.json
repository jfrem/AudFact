{
  "name": "usuario/php-backend",
  "description": "Backend PHP MVC con API REST JSON",
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Core\\": "core/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "ext-pdo": "*",
    "guzzlehttp/guzzle": "^7.10",
    "firebase/php-jwt": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}