# development | production
APP_ENV=development
WWWUSER_ID=1000
WWWGROUP_ID=1000

WRAP_API_BASE=http://nginx
WEBHOOK_URL=http://localhost:8080/app/wrap/webhook.php
CAPABILITIES_URL=http://localhost:8080/app/wrap/capabilities.php
MCP_WEBHOOK_SECRET=your_secure_random_string_here

DB_TYPE=sqlsrv
DB_HOST=localhost
DB_PORT=1433
DB_NAME=mi_base
DB_USER=sa
DB_PASS=
DB_POOLING=1
# Producción: DB_ENCRYPT=yes DB_TRUST_SERVER_CERT=no (requiere certificado válido)
DB_ENCRYPT=no
DB_TRUST_SERVER_CERT=yes

# Base de datos secundaria (conexion nombrada: secondary)
SECONDARY_DB_HOST=localhost
SECONDARY_DB_PORT=1433
SECONDARY_DB_NAME=mi_base_secundaria
SECONDARY_DB_USER=sa
SECONDARY_DB_PASS=
SECONDARY_DB_POOLING=1
SECONDARY_DB_ENCRYPT=no
SECONDARY_DB_TRUST_SERVER_CERT=yes

# Compatibilidad legado (evitar en nuevos despliegues)
# DB2_HOST=
# DB2_PORT=
# DB2_NAME=
# DB2_USER=
# DB2_PASS=

# Política runtime actual:
# - SELECT/consultas => conexión de lectura `secondary` (usa SECONDARY_DB_* o fallback DB2_*)
# - INSERT/UPDATE/DELETE/MERGE => conexión `default` (DB_*)

GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_TLS_VERIFY=1

REQUEST_TIMEOUT_MS=60000
LOG_LEVEL=info
LOG_RETENTION_DAYS=7
LOG_MAX_SIZE_MB=10
# Produccion: lista separada por comas (sin espacios), ej:
# ALLOWED_ORIGINS=https://app.empresa.com,https://admin.empresa.com
ALLOWED_ORIGINS=
MAX_JSON_SIZE=1048576

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TEMPERATURE=0.0
GEMINI_TIMEOUT=300
GEMINI_TOP_P=
GEMINI_TOP_K=
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_RESPONSE_MIME=application/json
GEMINI_MEDIA_RESOLUTION=
GEMINI_THINKING_BUDGET=

# ── Timeouts de Auditoría
AUDIT_BATCH_MAX_LIMIT=100
AUDIT_BATCH_TIMEOUT=3600
AUDIT_NGINX_READ_TIMEOUT=3600
AUDIT_FPM_TERMINATE_TIMEOUT=3600

# ── Seguridad en Producción ──
# IMPORTANTE: En producción, NO almacene secretos en este archivo.
# Opciones recomendadas:
#   1. Docker secrets:  docker secret create db_pass <file>
#   2. Azure Key Vault: az keyvault secret set --vault-name X --name DB_PASS --value Y
#   3. Variables de entorno del sistema (no archivos .env)
# Secretos a migrar: DB_PASS, GEMINI_API_KEY, GOOGLE_DRIVE_PRIVATE_KEY, MCP_WEBHOOK_SECRET

